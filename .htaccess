# Ativar o motor de reescrita do Apache
RewriteEngine On

# -----------------------------------------------------------------
# ETAPA 1: Redirecionamento Externo (SEO)
# Força o navegador a mudar de /pagina.html ou .php para /pagina
# -----------------------------------------------------------------

# Redirecionar .html para URL limpa
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s([^.]+)\.html [NC]
RewriteRule ^ %1 [R=301,L]

# Redirecionar .php para URL limpa
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s([^.]+)\.php [NC]
RewriteRule ^ %1 [R=301,L]

# -----------------------------------------------------------------
# ETAPA 2: Reescrita Interna (Servidor)
# Lê a URL limpa e serve o arquivo físico correspondente
# -----------------------------------------------------------------

# Regra para servir arquivos .html
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^(.*)$ $1.html [L]

# Regra para servir arquivos .php
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^(.*)$ $1.php [L]
